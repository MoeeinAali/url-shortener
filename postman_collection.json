{
  "info": {
    "_postman_id": "2f6df483-b6db-42ff-9291-20f1306e17d5",
    "name": "URL Shortener CQRS API",
    "description": "Postman collection for the URL Shortener project implemented with CQRS.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Commands",
      "item": [
        {
          "name": "Create Link",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"{{longUrl}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/links",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "links"
              ]
            },
            "description": "Creates a short link (write model in PostgreSQL, projection to Redis via NATS) and stores returned short code in collection variables."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "pm.test('Response has short code', function () {",
                  "  pm.expect(json.short_code).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Response echoes input url', function () {",
                  "  pm.expect(json.long_url).to.eql(pm.collectionVariables.get('longUrl'));",
                  "});",
                  "",
                  "pm.collectionVariables.set('shortCode', json.short_code);"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Disable Link",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/links/{{shortCode}}/disable",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "links",
                "{{shortCode}}",
                "disable"
              ]
            },
            "description": "Disables a link by short code on write model. Read model update is asynchronous."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "pm.test('Disable response has status=disabled', function () {",
                  "  pm.expect(json.status).to.eql('disabled');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Queries",
      "item": [
        {
          "name": "Redirect (GET /:short)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{shortCode}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{shortCode}}"
              ]
            },
            "description": "Resolves the short link from Redis and returns HTTP 302 redirect. After disable, due to eventual consistency, it may briefly still return 302 before becoming 404."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 302 or 404', function () {",
                  "  pm.expect([302, 404]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 302) {",
                  "  pm.test('Has Location header on redirect', function () {",
                  "    pm.expect(pm.response.headers.get('Location')).to.be.a('string').and.not.empty;",
                  "  });",
                  "  pm.collectionVariables.set('redirectLocation', pm.response.headers.get('Location'));",
                  "});"
                ]
              }
            }
          ],
          "protocolProfileBehavior": {
            "followRedirects": false
          },
          "response": []
        },
        {
          "name": "Stats (GET /links/:short/stats)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/links/{{shortCode}}/stats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "links",
                "{{shortCode}}",
                "stats"
              ]
            },
            "description": "Returns click stats from read model."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "pm.test('Stats response shape is valid', function () {",
                  "  pm.expect(json.short_code).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.clicks).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "longUrl",
      "value": "https://example.com/some/long/path"
    },
    {
      "key": "shortCode",
      "value": ""
    },
    {
      "key": "redirectLocation",
      "value": ""
    }
  ]
}
